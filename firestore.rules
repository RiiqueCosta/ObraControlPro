rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null && request.auth.token.email.matches('(?i).*luizcosta8604.*'))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validators ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nome', 'email', 'role', 'ativo', 'criadoEm']) &&
             data.keys().size() == 6 &&
             data.id == request.auth.uid &&
             data.nome is string && data.nome.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             (data.role == 'user' || (data.role == 'admin' && data.email.matches('(?i).*luizcosta8604.*'))) &&
             data.ativo is bool &&
             (data.criadoEm == request.time || data.criadoEm is timestamp);
    }

    function isValidObra(data) {
      return data.keys().hasAll(['id', 'nome', 'status', 'dataInicio', 'criadoPor', 'criadoEm']) &&
             data.keys().size() >= 6 && data.keys().size() <= 12 &&
             data.id is string && isValidId(data.id) &&
             data.nome is string && data.nome.size() <= 255 &&
             data.status in ['ativa', 'pausada', 'finalizada'] &&
             data.dataInicio is string && data.dataInicio.size() >= 8 &&
             data.criadoPor == request.auth.uid &&
             (data.criadoEm == request.time || data.criadoEm is timestamp);
    }

    function isValidLancamento(data) {
      return data.keys().hasAll(['id', 'obraId', 'data', 'criadoPor', 'criadoEm']) &&
             data.keys().size() >= 5 && data.keys().size() <= 25 &&
             data.id is string && isValidId(data.id) &&
             data.obraId is string && isValidId(data.obraId) &&
             data.data is string && data.data.size() >= 8 &&
             data.criadoPor == request.auth.uid &&
             (data.criadoEm == request.time || data.criadoEm is timestamp);
    }

    // --- Collection Routes ---

    // Users: Can read their own, admins can read all
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'email', 'ativo']);
      allow list: if isAdmin() || isOwner(userId);
    }

    // Obras: All users can see, only creators/admins can edit
    match /obras/{obraId} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidObra(incoming());
      
      allow update: if isSignedIn() && 
                    (existing().criadoPor == request.auth.uid || isAdmin()) && 
                    isValidObra(incoming()) &&
                    incoming().criadoPor == existing().criadoPor &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'endereco', 'cliente', 'status', 'dataInicio', 'observacoes', 'atualizadoEm']);
      
      allow delete: if isSignedIn() && (existing().criadoPor == request.auth.uid || isAdmin());
    }

    // Lancamentos: All users can see, creators, obra owners, and admins can edit
    match /lancamentos/{lancamentoId} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidLancamento(incoming());
      
      allow update: if isSignedIn() && 
                    (
                      existing().criadoPor == request.auth.uid || 
                      isAdmin() || 
                      get(/databases/$(database)/documents/obras/$(existing().obraId)).data.criadoPor == request.auth.uid
                    ) && 
                    isValidLancamento(incoming()) &&
                    incoming().criadoPor == existing().criadoPor &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'data', 'servicos', 'climaManha', 'climaTarde', 'efetivo', 
                      'totalFuncionarios', 'empresasTerceirizadas', 'observacoes', 
                      'fotos', 'atualizadoEm', 'obraNome', 'id', 'obraId', 'criadoEm', 'criadoPor'
                    ]);
      
      allow delete: if isSignedIn() && (
        existing().criadoPor == request.auth.uid || 
        isAdmin() || 
        get(/databases/$(database)/documents/obras/$(existing().obraId)).data.criadoPor == request.auth.uid
      );
    }
  }
}
